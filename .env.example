# PostgreSQL connection string from Neon (or any PostgreSQL provider)
# Get this from: https://neon.tech → your project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@host/wardline?sslmode=require

# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# URL where the patient portal is deployed (used for CORS).
# Set this after you deploy to Vercel.
# Example: https://wardline.vercel.app
PATIENT_PORTAL_URL=

# Railway sets PORT automatically — don't change this in production
PORT=4000
